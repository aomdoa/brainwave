// prisma/schema.prisma
datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  userId            Int      @id @default(autoincrement())
  name              String
  email             String   @unique
  password          String?
  isConfirmed       Boolean  @default(false)
  authLength        String   @default("4h")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  forgotPassToken   String?
  forgotPassExpiry  DateTime?

  // Relations
  thoughts      Thought[]      @relation("ThoughtToUser")
  tags          Tag[]          @relation("UserToTag")
  subscriptions Subscription[] @relation("UserToSubscription")
  oAuth         UserOAuth[]    @relation("UserToOAuth")
}

model UserOAuth {
  userOAuthId     Int @id @default(autoincrement())
  userId          Int
  provider        OAuthProvider
  providerUserId  String

  // Relation
  user  User  @relation("UserToOAuth", fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model Thought {
  thoughtId Int    @id @default(autoincrement())
  title     String
  body      String
  status    Status @default(ACTIVE)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  lastFollowUp DateTime?
  nextReminder DateTime?

  // Ownership
  userId Int
  user   User @relation("ThoughtToUser", fields: [userId], references: [userId], onDelete: Cascade)

  // Tags (many-to-many)
  tags Tag[] @relation("TagToThought")

  // Graph relations
  thoughtRelationsOne ThoughtRelation[] @relation("RelationThoughtOne")
  thoughtRelationsTwo ThoughtRelation[] @relation("RelationThoughtTwo")

  // History
  bodyHistories ThoughtBodyHistory[] @relation("ThoughtToThoughtBodyHistory")

  @@index([userId])
}

model ThoughtBodyHistory {
  thoughtBodyHistoryId  Int       @id @default(autoincrement())
  thoughtId             Int
  createdAt             DateTime  @default(now())
  body                  String
  thought               Thought   @relation("ThoughtToThoughtBodyHistory", fields: [thoughtId], references: [thoughtId], onDelete: Cascade)
  @@index([thoughtId])
}

model Tag {
  tagId Int    @id @default(autoincrement())
  name  String
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ownership
  userId Int
  user   User @relation("UserToTag", fields: [userId], references: [userId], onDelete: Cascade)

  // Relations
  thoughts Thought[] @relation("TagToThought")

  @@unique([userId, name])
  @@index([userId])
}

model ThoughtRelation {
  thoughtRelationId Int          @id @default(autoincrement())
  relationType      RelationType @default(RELATED)
  notes             String?

  createdAt DateTime @default(now())

  thoughtOneId Int
  thoughtTwoId Int

  thoughtOne Thought @relation("RelationThoughtOne", fields: [thoughtOneId], references: [thoughtId], onDelete: Cascade)
  thoughtTwo Thought @relation("RelationThoughtTwo", fields: [thoughtTwoId], references: [thoughtId], onDelete: Cascade)

  @@unique([thoughtOneId, thoughtTwoId])
  @@index([thoughtOneId])
  @@index([thoughtTwoId])
}

model Subscription {
  subscriptionId  Int @id @default(autoincrement())
  userId          Int
  endpoint        String
  p256dh          String
  auth            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // relations
  user   User @relation("UserToSubscription", fields: [userId], references: [userId], onDelete: Cascade)
  @@unique([endpoint])
  @@index([userId])
}

enum Status {
  ACTIVE
  INACTIVE
  CLOSED
}

enum RelationType {
  RELATED
  CAUSES
  CONTRADICTS
  SUPPORTS
  DERIVES_FROM
}

enum OAuthProvider {
  GOOGLE
}