{
  "name": "@brainwave/shared",
  "version": "1.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "yarn rimraf ./dist",
    "build:types": "tsc --emitDeclarationOnly",
    "build:js": "tsup src/index.ts --format esm,cjs --out-dir dist",
    "build": "yarn clean && yarn build:types && yarn build:js",
    "package": "npm unpublish -f @brainwave/shared@$npm_package_version --registry http://localhost:4873 && npm publish --registry http://localhost:4873"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
