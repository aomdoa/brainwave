{
  "name": "@brainwave/backendaws",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf ./dist ./build",
    "lint": "yarn eslint --ext .ts ./src",
    "spell": "cspell ./src/**/*.ts",
    "pretty": "prettier --write ./src/**/*.ts",
    "build": "yarn clean && yarn lint && yarn pretty && yarn spell && tsc --noEmit && ./_scripts/build.sh",
    "deploy": "bash _scripts/deploy.sh",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:setup": "NODE_ENV=development npx tsx _scripts/setup-local-db.ts",
    "local": "NODE_ENV=development npx tsx _scripts/run-local.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1021.0",
    "@aws-sdk/lib-dynamodb": "^3.1021.0",
    "bcryptjs": "^3.0.3",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@types/aws-lambda": "^8.10.140",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.0",
    "cspell": "^9.7.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "nock": "^14.0.11",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
